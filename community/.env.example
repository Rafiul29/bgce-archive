# General Service Info
VERSION=1.0.0
MODE=debug
SERVICE_NAME=community
HTTP_PORT=8082

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production

# APM Configuration (optional - leave empty if not using)
APM_SERVICE_NAME=
APM_SERVER_URL=
APM_SECRET_TOKEN=
APM_ENVIRONMENT=development

# RabbitMQ Configuration
RABBITMQ_URL=amqp://admin:admin@localhost:5672
RMQ_RECONNECT_DELAY=5
RMQ_RETRY_INTERVAL=600
RMQ_QUEUE_PREFIX=community-dev

# Database Configuration
COMMUNITY_DB_DSN=postgresql://postgres:root@localhost:5432/community_db?sslmode=disable
COMMUNITY_DB_DRIVER=postgres
